{
  "name": "mailcheck",
  "title": "mailcheck",
  "description": "Reduce misspelled email addresses in your forms.",
  "keywords": [
    "form",
    "email",
    "spell check"
  ],
  "version": "1.1.2",
  "author": {
    "name": "Derrick Ko",
    "url": "http://derrickko.com",
    "email": "hello@derrickko.com"
  },
  "maintainers": [
    {
      "name": "Wei Lu",
      "url": "http://neo.com",
      "email": "wei@neo.com"
    }
  ],
  "licenses": [
    {
      "type": "MIT",
      "url": "https://github.com/mailcheck/mailcheck/blob/master/LICENSE"
    }
  ],
  "bugs": "https://github.com/mailcheck/mailcheck/issues",
  "homepage": "https://github.com/mailcheck/mailcheck",
  "docs": "https://github.com/mailcheck/mailcheck/blob/master/README.md",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "husky": "^9.0.0",
    "jasmine": "^5.0.0",
    "terser": "^5.0.0"
  },
  "main": "src/mailcheck.js",
  "repository": {
    "type": "git",
    "url": "git://github.com/mailcheck/mailcheck.git"
  },
  "scripts": {
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "test": "jasmine",
    "minify": "terser src/mailcheck.js -o src/mailcheck.min.js --preamble '/*! mailcheck v1.1.2 @licence MIT */'",
    "build": "npm run lint && npm run test && npm run minify",
    "prepare": "husky"
  }
}
